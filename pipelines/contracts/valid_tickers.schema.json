{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://applied-finance.local/contracts/valid_tickers.schema.json",
  "title": "Valid tickers for a covariance window",
  "description": "Companion to gold.cov_matrix_*: lists the tickers with complete coverage in the window.",
  "type": "object",
  "required": ["window_label", "as_of", "source_run_id", "valid_tickers", "excluded_tickers"],
  "additionalProperties": false,
  "properties": {
    "window_label": { "type": "string", "enum": ["1y", "5y", "full"] },
    "as_of": { "type": "string", "format": "date" },
    "source_run_id": { "type": "string", "minLength": 1 },
    "window_start": { "type": "string", "format": "date" },
    "window_end": { "type": "string", "format": "date" },
    "n_total": { "type": "integer", "minimum": 0 },
    "n_valid": { "type": "integer", "minimum": 0 },
    "n_excluded": { "type": "integer", "minimum": 0 },
    "exclusions_by_reason": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 }
    },
    "shrinkage_target": { "type": "string", "enum": ["none", "identity", "constant_correlation"] },
    "shrinkage_intensity": { "type": "number", "minimum": 0, "maximum": 1 },
    "min_eigenvalue": { "type": "number" },
    "valid_tickers": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[A-Z0-9]{4,6}\\.SA$" }
    },
    "excluded_tickers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ticker", "reason"],
        "additionalProperties": false,
        "properties": {
          "ticker": { "type": "string", "pattern": "^[A-Z0-9]{4,6}\\.SA$" },
          "reason": { "type": "string", "enum": ["insufficient_history", "delisted", "low_liquidity"] },
          "coverage": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    }
  }
}
