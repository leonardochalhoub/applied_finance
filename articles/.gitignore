# LaTeX build artifacts — only .tex and compile-stamp.tex are tracked.
# PDFs are produced in CI and copied to app/public/articles/, not committed.
*.pdf
*.aux
*.log
*.out
*.toc

# CI-generated artifacts: numbers.tex (commands from TS export), data/*.json
# (raw experiment results), figures/*.pdf (matplotlib outputs). All produced
# fresh on every CI run; never committed.
numbers.tex
data/
figures/*.pdf
*.lof
*.lot
*.fls
*.fdb_latexmk
*.synctex.gz
*.bbl
*.blg
*.bcf
*.run.xml
*.nav
*.snm
*.vrb
